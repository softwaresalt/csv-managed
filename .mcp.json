{
  "mcpServers": {
    "engram": {
      "type": "stdio",
      "command": "D:/Tools/engram.exe",
      "args": ["shim"],
      "env": {
        "ENGRAM_WORKSPACE": "D:\\Source\\GitHub\\csv-managed"
      }
    },
    "graphtor-docs": {
      "command": ".graphtor/bin/graphtor-docs.exe",
      "args": ["serve"],
      "transport": "stdio"
    },
    "backlogit": {
      "type": "stdio",
      "command": "backlogit",
      "args": ["mcp"],
      "env": {
        "BACKLOGIT_WORKSPACE": "D:\\Source\\GitHub\\csv-managed"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "agent-intercom": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://127.0.0.1:3000/mcp?workspace_id=csv-managed"]
    },
    "tavily": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}"]
    },
    "github": {
      "type": "stdio",
      "command": "pwsh",
      "args": [
        "-Command",
        "$env:GITHUB_PERSONAL_ACCESS_TOKEN = (gh auth token); npx -y @modelcontextprotocol/server-github"
      ]
    }
  }
}
